model User {
  id                              String                           @id @default(uuid()) @db.Uuid
  email                           String                           @unique
  passwordHash                    String?
  name                            String?
  phone                           String?
  image                           String?
  status                          UserStatus                       @default(PENDING_VERIFICATION)
  accountType                     AccountType                      @default(CUSTOMER)
  companyId                       String?                          @db.Uuid
  departmentId                    String?                          @db.Uuid
  mustChangePassword              Boolean                          @default(false)
  temporaryPasswordExpiresAt      DateTime?
  activatedAt                     DateTime?
  emailVerified                   DateTime?
  passwordChangedAt               DateTime?
  lastLoginAt                     DateTime?
  deletedAt                       DateTime?
  isTestData                      Boolean                          @default(false)
  createdAt                       DateTime                         @default(now())
  updatedAt                       DateTime                         @updatedAt
  accounts                        Account[]
  sessions                        Session[]
  roles                           UserRole[]
  assignedRoles                   UserRole[]                       @relation("UserRoleAssigner")
  addresses                       Address[]
  customerProfile                 CustomerProfile?
  carts                           Cart[]
  wishlists                       Wishlist[]
  orders                          Order[]
  couponRedemptions               CouponRedemption[]
  couponCustomers                 CouponCustomer[]
  quotationRequests               QuotationRequest[]
  quotations                      Quotation[]                      @relation("CustomerQuotations")
  reviews                         Review[]
  notifications                   Notification[]
  inventoryMovements              InventoryMovement[]              @relation("InventoryMovementActor")
  reviewedPaymentProofs           PaymentProof[]                   @relation("PaymentProofReviewer")
  uploadedPaymentProofs           PaymentProof[]                   @relation("PaymentProofUploader")
  orderStatusChanges              OrderStatusHistory[]             @relation("OrderStatusActor")
  quotationStatusChanges          QuotationStatusHistory[]         @relation("QuotationStatusActor")
  auditLogs                       AuditLog[]                       @relation("AuditActor")
  paymentSubmissions              PaymentSubmission[]              @relation("PaymentSubmitter")
  paymentVerifications            PaymentVerification[]            @relation("PaymentVerifier")
  deliveryEvents                  DeliveryTrackingEvent[]          @relation("DeliveryEventActor")
  partnershipApplications         PartnershipApplication[]         @relation("PartnershipApplicant")
  reviewedPartnershipApplications PartnershipApplication[]         @relation("PartnershipReviewer")
  managedPartnershipApplications  PartnershipApplication[]         @relation("ApplicationAccountManager")
  partnerships                    Partnership[]                    @relation("PartnerOwner")
  managedPartnerships             Partnership[]                    @relation("PartnerAccountManager")
  partnershipStatusChanges        PartnershipStatusHistory[]       @relation("PartnershipStatusActor")
  partnershipDocuments            PartnershipApplicationDocument[] @relation("PartnershipDocumentUploader")
  reviewedPartnershipDocuments    PartnershipApplicationDocument[] @relation("PartnershipDocumentReviewer")
  partnershipReviews              PartnershipReview[]              @relation("PartnershipReviewActor")
  partnerMessages                 PartnerMessage[]                 @relation("PartnerMessageAuthor")
  company                         CompanyProfile?                  @relation("CompanyUsers", fields: [companyId], references: [id], onDelete: SetNull)
  department                      Department?                      @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  invitationsReceived             UserInvitation[]                 @relation("InvitedUser")
  invitationsSent                 UserInvitation[]                 @relation("InvitationCreator")
  assignedRfqs                    RfqOpportunity[]                 @relation("RfqAssignee")
  createdRfqs                     RfqOpportunity[]                 @relation("RfqCreator")
  reviewedRfqAnalyses             RfqAnalysis[]                    @relation("RfqAnalysisReviewer")
  rfqApprovals                    RfqApproval[]                    @relation("RfqApprover")
  rfqStatusChanges                RfqStatusHistory[]               @relation("RfqStatusActor")
  rfqSourceUploads                RfqSource[]                      @relation("RfqSourceUploader")
  createdQuotations               Quotation[]                      @relation("QuotationCreator")
  helpDeskTickets                 HelpDeskTicket[]                 @relation("HelpDeskCustomer")
  assignedHelpDeskTickets         HelpDeskTicket[]                 @relation("HelpDeskAssignee")
  assignedServiceTasks            ServiceTask[]                    @relation("ServiceTaskAssignee")
  createdServiceTasks             ServiceTask[]                    @relation("ServiceTaskCreator")
  helpDeskActivities              HelpDeskActivity[]               @relation("HelpDeskActivityActor")
  createdInvoices                 Invoice[]                        @relation("InvoiceCreator")
  updatedInvoices                 Invoice[]                        @relation("InvoiceUpdater")
  createdDeliveryNotes            DeliveryNote[]                   @relation("DeliveryNoteCreator")
  updatedDeliveryNotes            DeliveryNote[]                   @relation("DeliveryNoteUpdater")
  responsibleDeliveryNotes        DeliveryNote[]                   @relation("DeliveryNoteResponsible")
  confirmedDeliveryNotes          DeliveryNote[]                   @relation("DeliveryNoteConfirmer")
  generatedBusinessDocuments      BusinessDocument[]               @relation("BusinessDocumentGenerator")
  sentBusinessDocuments           DocumentDispatch[]               @relation("DocumentDispatchSender")
  returnCases                     ReturnCase[]                     @relation("ReturnCustomer")
  createdReturnCases              ReturnCase[]                     @relation("ReturnCreator")
  assignedReturnCases             ReturnCase[]                     @relation("ReturnReviewer")
  technicianReturnCases           ReturnCase[]                     @relation("ReturnTechnician")
  returnCaseEvents                ReturnCaseEvent[]                @relation("ReturnEventActor")
  returnInspections               ReturnInspection[]               @relation("ReturnInspector")
  returnDecisions                 ReturnResolution[]               @relation("ReturnDecisionMaker")
  returnRefundApprovals           ReturnRefund[]                   @relation("ReturnRefundApprover")
  returnRefundPayments            ReturnRefundPayment[]            @relation("ReturnRefundProcessor")
  assignedReturnRepairs           ReturnRepair[]                   @relation("ReturnRepairAssignee")
  completedReturnRepairs          ReturnRepair[]                   @relation("ReturnRepairCompleter")
  assignedReturnReplacements      ReturnReplacement[]              @relation("ReturnReplacementAssignee")
  completedReturnReplacements     ReturnReplacement[]              @relation("ReturnReplacementCompleter")
  distributorClaimEvents          DistributorClaimEvent[]          @relation("DistributorClaimEventActor")
  distributorRecoveries           DistributorRecovery[]            @relation("DistributorRecoveryRecorder")
  requestedTransports             TransportRecord[]                @relation("TransportRequester")
  responsibleTransports           TransportRecord[]                @relation("TransportResponsibleUser")
  drivenTransports                TransportRecord[]                @relation("TransportDriver")
  technicianTransports            TransportRecord[]                @relation("TransportTechnician")
  customerTransports              TransportRecord[]                @relation("TransportCustomer")
  transportApprovals              TransportRecord[]                @relation("TransportApprover")
  transportPayments               TransportPayment[]               @relation("TransportPaymentProcessor")
  transportExpenses               TransportExpense[]               @relation("TransportExpenseSubmitter")
  approvedTransportExpenses       TransportExpense[]               @relation("TransportExpenseApprover")
  transportReimbursements         StaffTransportReimbursement[]    @relation("TransportReimbursementEmployee")
  approvedTransportReimbursements StaffTransportReimbursement[]    @relation("TransportReimbursementApprover")
  transportEvents                 TransportEvent[]                 @relation("TransportEventActor")
  partnershipAgreementVersions    PartnershipAgreementVersion[]    @relation("PartnershipAgreementVersionCreator")
  partnershipAgreementSignatures  PartnershipAgreementSignature[]  @relation("PartnershipAgreementSigner")
  partnershipChangesRequested     PartnershipChange[]              @relation("PartnershipChangeRequester")
  partnershipChangesApproved      PartnershipChange[]              @relation("PartnershipChangeApprover")

  @@index([status, createdAt])
  @@index([deletedAt])
  @@index([companyId, status])
  @@index([departmentId])
}

model Account {
  id                String  @id @default(uuid()) @db.Uuid
  userId            String  @db.Uuid
  type              String
  provider          String
  providerAccountId String
  refreshToken      String? @db.Text
  accessToken       String? @db.Text
  expiresAt         Int?
  tokenType         String?
  scope             String?
  idToken           String? @db.Text
  sessionState      String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(uuid()) @db.Uuid
  sessionToken String   @unique
  userId       String   @db.Uuid
  expires      DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expires])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@index([expires])
}

model Role {
  id          String           @id @default(uuid()) @db.Uuid
  name        String           @unique
  slug        String           @unique
  description String?
  isSystem    Boolean          @default(false)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  users       UserRole[]
  permissions RolePermission[]
  invitations UserInvitation[]
}

model Permission {
  id          String           @id @default(uuid()) @db.Uuid
  key         String           @unique
  description String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  roles       RolePermission[]
}

model UserRole {
  userId     String   @db.Uuid
  roleId     String   @db.Uuid
  assignedBy String?  @db.Uuid
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assigner   User?    @relation("UserRoleAssigner", fields: [assignedBy], references: [id], onDelete: SetNull)

  @@id([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  roleId       String           @db.Uuid
  permissionId String           @db.Uuid
  effect       PermissionEffect @default(ALLOW)
  createdAt    DateTime         @default(now())
  role         Role             @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission       @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId, effect])
}

model CustomerProfile {
  id               String          @id @default(uuid()) @db.Uuid
  userId           String          @unique @db.Uuid
  firstName        String?
  lastName         String?
  marketingConsent Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  user             User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  company          CompanyProfile?
}

model CompanyProfile {
  id                    String           @id @default(uuid()) @db.Uuid
  customerProfileId     String           @unique @db.Uuid
  companyName           String
  registrationNo        String?
  vatNumber             String?
  purchaseOrderRequired Boolean          @default(false)
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  customerProfile       CustomerProfile  @relation(fields: [customerProfileId], references: [id], onDelete: Cascade)
  users                 User[]           @relation("CompanyUsers")
  departments           Department[]
  invitations           UserInvitation[]
  rfqs                  RfqOpportunity[]
}

model Department {
  id              String           @id @default(uuid()) @db.Uuid
  companyId       String?          @db.Uuid
  name            String
  description     String?
  isActive        Boolean          @default(true)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  company         CompanyProfile?  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  users           User[]
  invitations     UserInvitation[]
  rfqs            RfqOpportunity[]
  helpDeskTickets HelpDeskTicket[]

  @@unique([companyId, name])
  @@index([companyId, isActive])
}

model UserInvitation {
  id                  String          @id @default(uuid()) @db.Uuid
  userId              String          @db.Uuid
  invitedById         String          @db.Uuid
  roleId              String          @db.Uuid
  companyId           String?         @db.Uuid
  departmentId        String?         @db.Uuid
  accountType         AccountType
  activationTokenHash String          @unique
  expiresAt           DateTime
  acceptedAt          DateTime?
  createdAt           DateTime        @default(now())
  user                User            @relation("InvitedUser", fields: [userId], references: [id], onDelete: Cascade)
  invitedBy           User            @relation("InvitationCreator", fields: [invitedById], references: [id], onDelete: Restrict)
  role                Role            @relation(fields: [roleId], references: [id], onDelete: Restrict)
  company             CompanyProfile? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  department          Department?     @relation(fields: [departmentId], references: [id], onDelete: SetNull)

