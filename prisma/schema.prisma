  expenses               TransportExpense[]
  payments               TransportPayment[]
  allocations            TransportCostAllocation[]
  proofs                 TransportProof[]
  reimbursements         StaffTransportReimbursement[]
  documents              TransportDocument[]
  events                 TransportEvent[]

  @@index([status, scheduledAt])
  @@index([paymentStatus, createdAt])
  @@index([orderId, createdAt])
  @@index([returnCaseId, createdAt])
  @@index([providerId, createdAt])
  @@index([technicianId, scheduledAt])
  @@index([customerId, createdAt])
}

model TransportItem {
  id                    String          @id @default(uuid()) @db.Uuid
  transportId           String          @db.Uuid
  productId             String?         @db.Uuid
  orderItemId           String?         @db.Uuid
  description           String
  sku                   String?
  serialNumbers         String[]
  quantity              Int
  weightKg              Decimal?        @db.Decimal(12, 3)
  volumeM3              Decimal?        @db.Decimal(12, 4)
  packageCount          Int?
  conditionAtCollection String?
  handlingInstructions  String?         @db.Text
  createdAt             DateTime        @default(now())
  transport             TransportRecord @relation(fields: [transportId], references: [id], onDelete: Cascade)
  product               Product?        @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([transportId])
  @@index([productId])
}

model TransportQuote {
  id             String               @id @default(uuid()) @db.Uuid
  transportId    String               @db.Uuid
  providerId     String?              @db.Uuid
  quoteNumber    String?
  status         TransportQuoteStatus @default(RECEIVED)
  quotedAmount   Decimal              @db.Decimal(19, 4)
  vatAmount      Decimal              @default(0) @db.Decimal(19, 4)
  additionalFees Decimal              @default(0) @db.Decimal(19, 4)
  expiresAt      DateTime?
  documentId     String?              @unique @db.Uuid
  notes          String?              @db.Text
  receivedAt     DateTime             @default(now())
  selectedAt     DateTime?
  transport      TransportRecord      @relation(fields: [transportId], references: [id], onDelete: Cascade)
  provider       TransportProvider?   @relation(fields: [providerId], references: [id], onDelete: SetNull)
  document       UploadedDocument?    @relation(fields: [documentId], references: [id], onDelete: Restrict)

  @@index([transportId, status])
  @@index([providerId, receivedAt])
}

model TransportCostComponent {
  id          String            @id @default(uuid()) @db.Uuid
  transportId String            @db.Uuid
  costTypeId  String            @db.Uuid
  description String?
  quantity    Decimal           @default(1) @db.Decimal(12, 3)
  unitRate    Decimal           @default(0) @db.Decimal(19, 4)
  netAmount   Decimal           @db.Decimal(19, 4)
  vatAmount   Decimal           @default(0) @db.Decimal(19, 4)
  totalAmount Decimal           @db.Decimal(19, 4)
  isActual    Boolean           @default(false)
  createdAt   DateTime          @default(now())
  transport   TransportRecord   @relation(fields: [transportId], references: [id], onDelete: Cascade)
  costType    TransportCostType @relation(fields: [costTypeId], references: [id], onDelete: Restrict)

  @@index([transportId, isActual])
  @@index([costTypeId])
}

model TransportExpense {
  id              String                 @id @default(uuid()) @db.Uuid
  transportId     String                 @db.Uuid
  submittedById   String                 @db.Uuid
  approvedById    String?                @db.Uuid
  status          TransportExpenseStatus @default(DRAFT)
  type            String
  expenseDate     DateTime
  amount          Decimal                @db.Decimal(19, 4)
  description     String?
  documentId      String?                @unique @db.Uuid
  submittedAt     DateTime?
  approvedAt      DateTime?
  rejectionReason String?                @db.Text
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  transport       TransportRecord        @relation(fields: [transportId], references: [id], onDelete: Cascade)
  submittedBy     User                   @relation("TransportExpenseSubmitter", fields: [submittedById], references: [id], onDelete: Restrict)
  approvedBy      User?                  @relation("TransportExpenseApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  document        UploadedDocument?      @relation(fields: [documentId], references: [id], onDelete: Restrict)

  @@index([status, createdAt])
  @@index([transportId])
}

model TransportPayment {
  id               String            @id @default(uuid()) @db.Uuid
  transportId      String            @db.Uuid
  processedById    String            @db.Uuid
  amount           Decimal           @db.Decimal(19, 4)
  paymentDate      DateTime
  method           String
  paymentReference String
  proofDocumentId  String?           @unique @db.Uuid
  notes            String?           @db.Text
  createdAt        DateTime          @default(now())
  transport        TransportRecord   @relation(fields: [transportId], references: [id], onDelete: Restrict)
  processedBy      User              @relation("TransportPaymentProcessor", fields: [processedById], references: [id], onDelete: Restrict)
  proofDocument    UploadedDocument? @relation(fields: [proofDocumentId], references: [id], onDelete: Restrict)

  @@index([transportId, paymentDate])
  @@index([paymentReference])
}

model TransportCostAllocation {
  id           String                    @id @default(uuid()) @db.Uuid
  transportId  String                    @db.Uuid
  productId    String?                   @db.Uuid
  orderId      String?                   @db.Uuid
  returnCaseId String?                   @db.Uuid
  method       TransportAllocationMethod
  basisValue   Decimal?                  @db.Decimal(19, 4)
  amount       Decimal                   @db.Decimal(19, 4)
  notes        String?
  createdAt    DateTime                  @default(now())
  transport    TransportRecord           @relation(fields: [transportId], references: [id], onDelete: Cascade)
  product      Product?                  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([transportId])
  @@index([productId])
}

model TransportProof {
  id                String                   @id @default(uuid()) @db.Uuid
  transportId       String                   @db.Uuid
  type              TransportProofType
  recipientName     String?
  occurredAt        DateTime
  signatureData     String?                  @db.Text
  latitude          Decimal?                 @db.Decimal(10, 7)
  longitude         Decimal?                 @db.Decimal(10, 7)
  condition         String?
  quantityConfirmed Boolean                  @default(false)
  missingItems      String?                  @db.Text
  damagedItems      String?                  @db.Text
  notes             String?                  @db.Text
  createdAt         DateTime                 @default(now())
  transport         TransportRecord          @relation(fields: [transportId], references: [id], onDelete: Cascade)
  documents         TransportProofDocument[]

  @@index([transportId, type])
}

model TransportProofDocument {
  id         String           @id @default(uuid()) @db.Uuid
  proofId    String           @db.Uuid
  documentId String           @unique @db.Uuid
  type       String
  createdAt  DateTime         @default(now())
  proof      TransportProof   @relation(fields: [proofId], references: [id], onDelete: Cascade)
  document   UploadedDocument @relation(fields: [documentId], references: [id], onDelete: Restrict)

  @@index([proofId])
}

model StaffTransportReimbursement {
  id                String                 @id @default(uuid()) @db.Uuid
  transportId       String                 @db.Uuid
  employeeId        String                 @db.Uuid
  approvedById      String?                @db.Uuid
  status            TransportExpenseStatus @default(SUBMITTED)
  expenseType       String
  expenseDate       DateTime
  amount            Decimal                @db.Decimal(19, 4)
  receiptDocumentId String?                @unique @db.Uuid
  approvalNote      String?                @db.Text
  paidAt            DateTime?
  paymentReference  String?
  createdAt         DateTime               @default(now())
  updatedAt         DateTime               @updatedAt
  transport         TransportRecord        @relation(fields: [transportId], references: [id], onDelete: Restrict)
  employee          User                   @relation("TransportReimbursementEmployee", fields: [employeeId], references: [id], onDelete: Restrict)
  approvedBy        User?                  @relation("TransportReimbursementApprover", fields: [approvedById], references: [id], onDelete: SetNull)
  receiptDocument   UploadedDocument?      @relation(fields: [receiptDocumentId], references: [id], onDelete: Restrict)

  @@index([status, createdAt])
  @@index([employeeId, status])
}

model TransportDocument {
  id          String           @id @default(uuid()) @db.Uuid
  transportId String           @db.Uuid
  documentId  String           @unique @db.Uuid
  type        String
  notes       String?
  createdAt   DateTime         @default(now())
  transport   TransportRecord  @relation(fields: [transportId], references: [id], onDelete: Cascade)
  document    UploadedDocument @relation(fields: [documentId], references: [id], onDelete: Restrict)

  @@index([transportId, type])
}

model TransportEvent {
  id           String           @id @default(uuid()) @db.Uuid
  transportId  String           @db.Uuid
  actorId      String?          @db.Uuid
  action       String
  fromStatus   TransportStatus?
  toStatus     TransportStatus?
  publicNote   String?          @db.Text
  internalNote String?          @db.Text
  before       Json?
  after        Json?
  createdAt    DateTime         @default(now())
  transport    TransportRecord  @relation(fields: [transportId], references: [id], onDelete: Cascade)
  actor        User?            @relation("TransportEventActor", fields: [actorId], references: [id], onDelete: SetNull)

  @@index([transportId, createdAt])
  @@index([action, createdAt])
}
